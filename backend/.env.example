# Copy this file to .env and fill in your own values. Never commit .env.

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-random-32-byte-hex-string

# --- Database ---
# Default is local SQLite, zero setup needed. For MySQL later:
# DATABASE_URL=mysql+pymysql://root:your_password@localhost/character_ai_db
DATABASE_URL=sqlite:///./database.db

# --- AI Provider ---
# One of: mock | gemini | groq
# "mock" works with no key at all, so you can build/test the whole app first.
AI_PROVIDER=mock

# Get a free key at https://aistudio.google.com (~1500 requests/day free)
GEMINI_API_KEY=

# Get a free key at https://console.groq.com - handy as a fallback if you
# hit Gemini's daily limit
GROQ_API_KEY=

# --- CORS ---
# Comma-separated list of origins allowed to call this API.
# "*" is fine for local dev; lock this down before deploying publicly.
CORS_ORIGINS=*
